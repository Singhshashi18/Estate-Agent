# =========================================================
# AI Estate-Planning Engagement Agent — environment config
# =========================================================

# --- Mode flags ---
DRY_RUN=true              # true = never actually post, only log
HUMAN_APPROVAL=true       # queue replies for manual review
MOCK_LLM=true             # true = use canned LLM responses (no API key needed)

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL_CLASSIFIER=gpt-4o-mini
OPENAI_MODEL_GENERATOR=gpt-4o-mini

# --- Reddit (fill in once client provides) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=estate-agent/1.0

# --- Product / link tracking ---
PRODUCT_URL=https://www.amazon.com/dp/EXAMPLE123
SHORT_DOMAIN=https://zp-estate.link
AFFILIATE_TAG=zachpeters-20

# --- Targets ---
SUBREDDITS=EstatePlanning,personalfinance,legaladvice
KEYWORDS=will,power of attorney,estate planning,probate,living trust,POA
POSTS_PER_SUBREDDIT=10

# --- Safety rails ---
MAX_REPLIES_PER_RUN=5
MAX_REPLIES_PER_SUB_RUN=2
REPLY_DELAY_SECONDS=30

# --- Database (Postgres) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/estate_agent
